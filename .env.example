# gg-asana — example env file
# Copy to `.env` and fill in real values. `.env` is gitignored.

# Asana Personal Access Token.
# Get one at https://app.asana.com/0/my-apps → "Personal access tokens" → "Create new token".
# Scope: full account access. Treat like a password — rotate immediately if leaked.
ASANA_PAT=

# Default project the scripts target when no --project flag is passed.
ASANA_DEFAULT_PROJECT_GID=

# Default workspace the scripts target when no --workspace flag is passed.
ASANA_DEFAULT_WORKSPACE_GID=
